# Managed by Ansible. Local changes may be overwritten.
# See faillock.conf(5).

# Directory where failure records are kept.
dir = {{ auth_faillock_dir if auth_faillock_dir is not none else '/var/run/faillock' }}

{% if auth_audit %}
# Log unknown user names into the system log.
audit
{% endif %}
{% if auth_silent %}
# Do not print informative messages.
silent
{% endif %}
{% if auth_no_log_info %}
# Do not log informative messages.
no_log_info
{% endif %}
# Deny access after this number of consecutive failed attempts.
deny = {{ auth_deny_after }}

# Failure interval in seconds.
fail_interval = {{ auth_fail_interval }}

# Unlock time in seconds.
unlock_time = {{ auth_unlock_time }}

{% if auth_even_deny_root %}
# Root can also be locked by faillock.
even_deny_root
{% endif %}
{% if auth_root_unlock_time is not none %}
# Root-specific unlock time in seconds.
root_unlock_time = {{ auth_root_unlock_time }}
{% endif %}
{% if auth_admin_group is not none %}
# Administrative group for faillock behavior.
admin_group = {{ auth_admin_group }}
{% endif %}
{% if auth_local_users_only %}
# Track only local users where supported by the PAM module.
local_users_only
{% endif %}
